      "lyrics": [
        { "section": "Verse 1" },
        { "text": "June heat on the console," },
        { "text": "fifteen-one comes alive," },
        { "text": "second spark of stable branches," },
        { "text": "kernels burning, systems thrive." },
        { "text": "Wireless signals glowing," },
        { "text": "newer code beneath the sky," },
        { "text": "packets cut through ember" },
        { "text": "where the old machines still fly." },
        { "section": "Pre-Chorus" },
        { "text": "Choose your path at boot time," },
        { "text": "let the scheduler blaze," },
        { "text": "spin the disks or wake the cloud," },
        { "text": "light the daemon through the haze." },
        { "section": "Chorus" },
        { "text": "Boot into the red," },
        { "text": "FreeBSD, full speed ahead," },
        { "text": "from amd64 highways" },
        { "text": "to riscv64 spread." },
        { "text": "Write it to the memstick," },
        { "text": "send it through the cloud," },
        { "text": "fifteen-one is rising," },
        { "text": "bright and fierce and proud." },
        { "section": "Verse 2" },
        { "text": "Base comes packed in images," },
        { "text": "first boot strikes the flame," },
        { "text": "updates like a flare line" },
        { "text": "calling out a brand-new name." },
        { "text": "C speaks toward tomorrow," },
        { "text": "twenty-three in sight," },
        { "text": "Unicode keeps glowing" },
        { "text": "with four thousand sparks of light." },
        { "section": "Pre-Chorus" },
        { "text": "Checksums in the firelight," },
        { "text": "signatures held high," },
        { "text": "trust is not a slogan," },
        { "text": "it’s the proof the bits comply." },
        { "section": "Chorus" },
        { "text": "Boot into the red," },
        { "text": "FreeBSD, full speed ahead," },
        { "text": "from armv7 footpaths" },
        { "text": "to powerpc tread." },
        { "text": "Write it to the memstick," },
        { "text": "spin it on ZFS," },
        { "text": "fifteen-one is rising" },
        { "text": "with a hot and steady breath." },
        { "section": "Bridge" },
        { "text": "For Peter, draw the boundary," },
        { "text": "capability and care," },
        { "text": "old ideas still guarding" },
        { "text": "new machines everywhere." },
        { "text": "From Multics ghosts to modern hosts," },
        { "text": "security’s refrain:" },
        { "text": "the lessons that we carry" },
        { "text": "are the roots inside the chain." },
        { "section": "Final Chorus" },
        { "text": "Boot into the red," },
        { "text": "FreeBSD, full speed ahead," },
        { "text": "clouds and boards and servers" },
        { "text": "all waking from the dead." },
        { "text": "Livefs for rescue," },
        { "text": "ports beneath red stars," },
        { "text": "fifteen-one is ready—" },
        { "text": "the future boots from where we are." }
      ]
    },
    {
      "slug": "freebsd-14-3-rc1",
