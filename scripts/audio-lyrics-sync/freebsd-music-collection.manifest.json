        { "text": "My desktop's flying out of sight." },
        { "section": "Chorus" },
        { "text": "FreeBSD, that's my way," },
        { "text": "Rock-solid every single day." },
        { "text": "No drama, no delay," },
        { "text": "FreeBSD, here to stay!" },
        { "section": "Bridge" },
        { "text": "Ports and power at my hand," },
        { "text": "Built to last, built to stand." },
        { "section": "Final Chorus" },
