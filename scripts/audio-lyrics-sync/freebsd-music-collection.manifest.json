      "lyrics": [
        { "section": "Intro" },
        { "text": "Sashka Echo presents." },
        { "section": "Chorus" },
        { "text": "Code like the wind, test what we find," },
        { "text": "RC1’s dropping, no bugs left behind!" },
        { "text": "Mirror sites waiting, ISO’s in the sky," },
        { "text": "Let’s spin up our systems, give this build a try!" },
        { "section": "Verse 2" },
        { "text": "PowerPC64le, and powerpcspe," },
        { "text": "The architectures dancing in perfect harmony." },
        { "text": "armv6 and v7, holding steady and strong," },
        { "text": "In the spirit of free software, we all belong." },
        { "section": "Bridge" },
        { "text": "No matter the system, no matter the core," },
        { "text": "FreeBSD’s the engine, opening doors." },
        { "text": "With every commit, we’re building the tide," },
        { "text": "For a stable tomorrow, with the code as our guide." },
        { "section": "Chorus" },
        { "text": "Code like the wind, test what we find," },
        { "text": "RC1’s dropping, no bugs left behind!" },
        { "text": "Mirror sites waiting, ISO’s in the sky," },
        { "text": "Let’s spin up our systems, give this build a try!" },
        { "section": "Outro" },
        { "text": "So fire up the console," },
        { "text": "and pull down the tree," },
        { "text": "FreeBSD’s calling," },
        { "text": "come set your system free!" }
